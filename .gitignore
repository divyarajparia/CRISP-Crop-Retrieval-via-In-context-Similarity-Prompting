# ------------------------------
# Python bytecode and caches
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp

# ------------------------------
# Cropper project outputs
# ------------------------------
# Local stray file seen in workspace
cropper/=4.40.0

# Runtime outputs and caches
cropper/cache/
cropper/results/
cropper/**/runs/
cropper/data/**/cache/
cropper/data/**/*.pkl

# Model / checkpoint artifacts
cropper/weights/
cropper/**/*.pt
cropper/**/*.pth
cropper/**/*.ckpt
cropper/**/*.onnx
cropper/**/*.h5
cropper/**/*.tfevents*

# Large downloaded dataset payloads
cropper/data/GAICD/images/
cropper/data/GAICD/annotations/
cropper/data/SACD/images/
cropper/data/SACD/masks/
cropper/data/FCDB/images/
cropper/data/FCDB/data/

# Handoff tarballs (multi-GB, too large for GitHub)
handoff/

# C/CUDA extension build outputs from bundled repos
cropper/data/GAICD_repo/**/build/
cropper/data/GAICD_repo/**/_ext/
cropper/data/GAICD_repo/**/*.so
cropper/data/GAICD_repo/**/*.o
cropper/data/GAICD_repo/**/*.a
